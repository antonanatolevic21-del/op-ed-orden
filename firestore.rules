rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid in [
          '5BWpHNMD2JNo3yb76FYa3lxXCh42',
          'V6TCpSnTCraD42sY67owCrRaVGZ2',
          'nfM5lNH7PCgl4h9fByPXXPUl8RH3',
          'JI5oT4J5cVbJ0nrkQfLiKta83qI2'
        ];
    }

    function validRoomId(roomId) {
      return roomId is string
        && roomId.size() > 0
        && roomId.size() <= 100;
    }

    function ownsProtectedProfile() {
      return signedIn()
        && resource.data.authUid is string
        && resource.data.authUid == request.auth.uid;
    }

    function createsOwnProfile() {
      return signedIn()
        && request.resource.data.authUid is string
        && request.resource.data.authUid == request.auth.uid;
    }

    function claimsLegacyProfile() {
      return signedIn()
        && (!('authUid' in resource.data) || resource.data.authUid == null || resource.data.authUid == '')
        && request.resource.data.authUid == request.auth.uid;
    }

    function updatesUnclaimedLegacyProfile() {
      return signedIn()
        && (!('authUid' in resource.data) || resource.data.authUid == null || resource.data.authUid == '')
        && (!('authUid' in request.resource.data) || request.resource.data.authUid == null || request.resource.data.authUid == '');
    }

    // Основной каталог меняют только администраторы.
    match /openings/{openingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Оценки и пользовательские тир-листы сохраняют вошедшие пользователи.
    match /ratings/{ratingId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /manualRanks/{rankId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /tierOrders/{orderId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /tierLabels/{labelId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /tierPlacements/{placementId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    // Новый профиль может создать только его Firebase-владелец.
    // Старый профиль без authUid разрешено один раз привязать к личному аккаунту.
    match /userProfiles/{profileId} {
      allow read: if true;
      allow create: if createsOwnProfile() || isAdmin();
      allow update: if ownsProtectedProfile() || claimsLegacyProfile() || updatesUnclaimedLegacyProfile() || isAdmin();
      allow delete: if ownsProtectedProfile() || isAdmin();
    }

    match /meta/{metaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /guessCollections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Настройки и корзину ежегодного ивента меняют только администраторы.
    match /eventSeasons/{seasonId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /eventBasket/{basketId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /eventAltLinks/{linkId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Участники могут сохранять свои оценки и уведомления.
    match /eventRatings/{ratingId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /eventNotifications/{notificationId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /eventPredictions/{seasonId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Параллельные комнаты Codenames и «Кто я».
    match /eventCodenames/{roomId} {
      allow read, create, update, delete: if signedIn() && validRoomId(roomId);
    }

    // Параллельные комнаты «Лучшее / худшее».
    match /bestWorstRooms/{roomId} {
      allow read, create, update, delete: if signedIn() && validRoomId(roomId);
    }

    match /bestWorstSubmissions/{submissionId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && request.resource.data.gameId is string
        && request.resource.data.gameId.size() > 0
        && request.resource.data.gameId.size() <= 100
        && request.resource.data.roundIndex is int
        && request.resource.data.roundIndex >= 0
        && request.resource.data.guesserKey is string
        && request.resource.data.guesserKey.size() > 0
        && request.resource.data.guesserKey.size() <= 60
        && request.resource.data.guesserName is string
        && request.resource.data.guesserName.size() <= 80
        && request.resource.data.answers is map;

      allow delete: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
